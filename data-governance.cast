[16.057012, "o", "            \"property\": \"storage.kind\","]
[16.077012, "o", "\r\n"]
[16.087012, "o", "            \"actual_value\": \"bucket\","]
[16.107012, "o", "\r\n"]
[16.117012, "o", "            \"operator\": \"eq\","]
