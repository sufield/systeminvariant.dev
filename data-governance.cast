[27.697012, "o", "        \"description\": \"Bucket does not have versioning enabled. Objects deleted or overwritten cannot be recovered.\\n\","]
[27.717012, "o", "\r\n"]
[27.727012, "o", "        \"action\": \"Enable versioning on the bucket using aws s3api put-bucket-versioning. Once enabled, configure lifecycle rules to manage noncurrent versions and control storage costs.\\n\","]
[27.747012, "o", "\r\n"]
[27.757012, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"kind\\\": \\\"bucket\\\",\\n    \\\"versioning\\\": {\\n      \\\"enabled\\\": true\\n    }\\n  }\\n}\\n\""]
