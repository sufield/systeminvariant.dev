[27.897012, "o", "\r\n"]
[27.907012, "o", "      \"invariant_id\": \"INV.S3.VERSION.002\","]
[27.927012, "o", "\r\n"]
[27.937012, "o", "      \"invariant_name\": \"Backup Buckets Must Have MFA Delete Enabled\","]
[27.957012, "o", "\r\n"]
[27.967012, "o", "      \"invariant_description\": \"S3 buckets tagged with backup=true must have MFA delete enabled. MFA delete requires multi-factor authentication to permanently delete object versions, protecting against ransomware attacks and accidental mass deletion of backup data. Without MFA delete, any principal with s3:DeleteObject permission can permanently destroy backup versions.\\n\","]
[27.987012, "o", "\r\n"]
[27.997012, "o", "      \"resource_id\": \"backup-compliance-archive\","]
