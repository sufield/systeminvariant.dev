[28.887012, "o", "\r\n"]
[28.897012, "o", "        \"description\": \"Backup bucket does not have MFA delete enabled. Any principal with s3:DeleteObject permission can permanently destroy backup versions.\\n\","]
[28.917012, "o", "\r\n"]
[28.927012, "o", "        \"action\": \"Enable MFA delete on the bucket using aws s3api put-bucket-versioning with the MFA flag. This requires the root account credentials and an MFA device. Only the root account can enable or disable MFA delete.\\n\","]
[28.947012, "o", "\r\n"]
[28.957012, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"tags\\\": {\\n      \\\"backup\\\": \\\"true\\\"\\n    },\\n    \\\"versioning\\\": {\\n      \\\"mfa_delete_enabled\\\": true\\n    }\\n  }\\n}\\n\""]
