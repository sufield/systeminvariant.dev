[15.297012, "o", "\r\n"]
[15.307012, "o", "      \"posture_drift\": {"]
[15.327012, "o", "\r\n"]
[15.337012, "o", "        \"pattern\": \"persistent\","]
[15.357012, "o", "\r\n"]
[15.367012, "o", "        \"episode_count\": 1"]
[15.387012, "o", "\r\n"]
[15.397012, "o", "      },"]
[15.417012, "o", "\r\n"]
[15.427012, "o", "      \"mitigation\": {"]
[15.447012, "o", "\r\n"]
[15.457012, "o", "        \"description\": \"Public Access Block is not fully enabled. The bucket has no safety net against accidental public exposure from policy or ACL changes.\\n\","]
[15.477012, "o", "\r\n"]
[15.487012, "o", "        \"action\": \"Enable all four Public Access Block settings on the bucket: BlockPublicAcls, IgnorePublicAcls, BlockPublicPolicy, RestrictPublicBuckets.\\n\","]
[15.507012, "o", "\r\n"]
[15.517012, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"kind\\\": \\\"bucket\\\",\\n    \\\"controls\\\": {\\n      \\\"public_access_fully_blocked\\\": true\\n    }\\n  }\\n}\\n\""]
[15.537012, "o", "\r\n"]
[15.547012, "o", "      },"]
[15.567012, "o", "\r\n"]
[15.577012, "o", "      \"remediation\": \"Enable all four Public Access Block settings on the bucket: BlockPublicAcls, IgnorePublicAcls, BlockPublicPolicy, RestrictPublicBuckets.\\n\""]
[15.597012, "o", "\r\n"]
[15.607012, "o", "    },"]
[15.627012, "o", "\r\n"]
[15.637012, "o", "    {"]
[15.657012, "o", "\r\n"]
[15.667012, "o", "      \"invariant_id\": \"INV.S3.GOVERNANCE.001\","]
[15.687012, "o", "\r\n"]
[15.697012, "o", "      \"invariant_name\": \"Data Classification Tag Required\","]
[15.717012, "o", "\r\n"]
[15.727012, "o", "      \"invariant_description\": \"S3 buckets must have a data-classification tag. Without this tag, tag-conditional invariants for PHI, PII, confidential data, backup integrity, and compliance retention cannot evaluate — the bucket silently passes all sensitivity-gated checks regardless of actual content.\\n\","]
[15.747012, "o", "\r\n"]
[15.757012, "o", "      \"resource_id\": \"backup-compliance-archive\","]
[15.777012, "o", "\r\n"]
[15.787012, "o", "      \"resource_type\": \"aws_s3_bucket\","]
[15.807012, "o", "\r\n"]
[15.817012, "o", "      \"resource_vendor\": \"aws\","]
[15.837012, "o", "\r\n"]
[15.847012, "o", "      \"evidence\": {"]
[15.867012, "o", "\r\n"]
[15.877012, "o", "        \"first_unsafe_at\": \"2026-01-14T00:00:00Z\","]
[15.897012, "o", "\r\n"]
