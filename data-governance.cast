[14.307012, "o", "\r\n"]
[14.317012, "o", "      \"invariant_id\": \"INV.S3.CONTROLS.001\","]
[14.337012, "o", "\r\n"]
[14.347012, "o", "      \"invariant_name\": \"Public Access Block Must Be Enabled\","]
[14.367012, "o", "\r\n"]
[14.377012, "o", "      \"invariant_description\": \"S3 buckets must have the public access block fully enabled. When disabled, the bucket has no safety net against accidental public exposure from policy or ACL changes. This detects the enabling condition for public access, not the exposure itself.\\n\","]
[14.397012, "o", "\r\n"]
[14.407012, "o", "      \"resource_id\": \"backup-compliance-archive\","]
[14.427012, "o", "\r\n"]
[14.437012, "o", "      \"resource_type\": \"aws_s3_bucket\","]
[14.457012, "o", "\r\n"]
[14.467012, "o", "      \"resource_vendor\": \"aws\","]
[14.487012, "o", "\r\n"]
