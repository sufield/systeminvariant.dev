[15.927012, "o", "\r\n"]
[15.937012, "o", "        \"unsafe_duration_hours\": 24,"]
[15.957012, "o", "\r\n"]
[15.967012, "o", "        \"threshold_hours\": 12,"]
[15.987012, "o", "\r\n"]
[15.997012, "o", "        \"misconfigurations\": ["]
[16.017012, "o", "\r\n"]
[16.027012, "o", "          {"]
