[14.145867, "o", "\r\n"]
[14.155867, "o", "      \"invariant_id\": \"INV.S3.CONTROLS.001\","]
[14.175867, "o", "\r\n"]
[14.185867, "o", "      \"invariant_name\": \"Public Access Block Must Be Enabled\","]
[14.205867, "o", "\r\n"]
[14.215867, "o", "      \"invariant_description\": \"S3 buckets must have the public access block fully enabled. When disabled, the bucket has no safety net against accidental public exposure from policy or ACL changes. This detects the enabling condition for public access, not the exposure itself.\\n\","]
[14.235867, "o", "\r\n"]
[14.245867, "o", "      \"resource_id\": \"corp-analytics-exports\","]
