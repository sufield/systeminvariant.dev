[15.045867, "o", "\r\n"]
[15.055867, "o", "        \"description\": \"Public Access Block is not fully enabled. The bucket has no safety net against accidental public exposure from policy or ACL changes.\\n\","]
[15.075867, "o", "\r\n"]
[15.085867, "o", "        \"action\": \"Enable all four Public Access Block settings on the bucket: BlockPublicAcls, IgnorePublicAcls, BlockPublicPolicy, RestrictPublicBuckets.\\n\","]
[15.105867, "o", "\r\n"]
[15.115867, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"kind\\\": \\\"bucket\\\",\\n    \\\"controls\\\": {\\n      \\\"public_access_fully_blocked\\\": true\\n    }\\n  }\\n}\\n\""]
[15.135867, "o", "\r\n"]
[15.145867, "o", "      },"]
[15.165867, "o", "\r\n"]
