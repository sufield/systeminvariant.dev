[39.972972, "o", "\r\n"]
[39.982972, "o", "      },"]
[40.002972, "o", "\r\n"]
[40.012972, "o", "      \"invariant_severity\": \"high\","]
[40.032972, "o", "\r\n"]
[40.042972, "o", "      \"mitigation\": {"]
[40.062972, "o", "\r\n"]
[40.072972, "o", "        \"description\": \"Signed upload policy uses prefix-wide write permissions instead of binding to an exact object key. This enables arbitrary overwrite and cross-tenant tampering.\\n\","]
[40.092972, "o", "\r\n"]
[40.102972, "o", "        \"action\": \"Change the signed upload policy to use an exact key condition (eq instead of starts-with) that binds each upload to a specific object path. Generate unique object keys server-side.\\n\","]
[40.122972, "o", "\r\n"]
[40.132972, "o", "        \"example\": \"{\\n  \\\"s3_upload\\\": {\\n    \\\"operation\\\": \\\"write\\\",\\n    \\\"allowed_key_mode\\\": \\\"exact\\\"\\n  }\\n}\\n\""]
[40.152972, "o", "\r\n"]
[40.162972, "o", "      },"]
[40.182972, "o", "\r\n"]
[40.192972, "o", "      \"remediation\": \"Change the signed upload policy to use an exact key condition (eq instead of starts-with) that binds each upload to a specific object path. Generate unique object keys server-side.\\n\""]
[40.212972, "o", "\r\n"]
[40.222972, "o", "    }"]
