[39.202972, "o", "      \"invariant_id\": \"INV.S3.WRITE.SCOPE.001\","]
[39.222972, "o", "\r\n"]
[39.232972, "o", "      \"invariant_name\": \"S3 Signed Upload Must Bind To Exact Object Key\","]
[39.252972, "o", "\r\n"]
[39.262972, "o", "      \"invariant_description\": \"Signed upload policies must restrict write permission to a single exact object key. Prefix-wide permissions (e.g., starts-with $key files/) enable arbitrary overwrite and cross-tenant tampering.\\n\","]
