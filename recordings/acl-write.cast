[13.994317, "o", "    {"]
[14.014317, "o", "\r\n"]
[14.024317, "o", "      \"invariant_id\": \"INV.S3.ACL.WRITE.001\","]
[14.044317, "o", "\r\n"]
[14.054317, "o", "      \"invariant_name\": \"No Public Write via ACL\","]
[14.074317, "o", "\r\n"]
[14.084317, "o", "      \"invariant_description\": \"S3 bucket ACLs must not grant write access to AllUsers or AuthenticatedUsers. ACL-based write access enables attackers to upload malicious objects or overwrite existing content.\\n\","]
[14.104317, "o", "\r\n"]
[14.114317, "o", "      \"resource_id\": \"platform-user-uploads\","]
[14.134317, "o", "\r\n"]
[14.144317, "o", "      \"resource_type\": \"aws_s3_bucket\","]
[14.164317, "o", "\r\n"]
[14.174317, "o", "      \"resource_vendor\": \"aws\","]
[14.194317, "o", "\r\n"]
[14.204317, "o", "      \"evidence\": {"]
[14.224317, "o", "\r\n"]
[14.234317, "o", "        \"first_unsafe_at\": \"2026-01-14T00:00:00Z\","]
[14.254317, "o", "\r\n"]
[14.264317, "o", "        \"last_seen_unsafe_at\": \"2026-01-15T00:00:00Z\","]
[14.284317, "o", "\r\n"]
[14.294317, "o", "        \"unsafe_duration_hours\": 24,"]
[14.314317, "o", "\r\n"]
[14.324317, "o", "        \"threshold_hours\": 12,"]
[14.344317, "o", "\r\n"]
[14.354317, "o", "        \"matched_properties\": ["]
[14.374317, "o", "\r\n"]
[14.384317, "o", "          {"]
[14.404317, "o", "\r\n"]
[14.414317, "o", "            \"path\": \"storage.visibility.public_write_via_acl\","]
[14.434317, "o", "\r\n"]
[14.444317, "o", "            \"value\": true"]
[14.464317, "o", "\r\n"]
[14.474317, "o", "          }"]
[14.494317, "o", "\r\n"]
[14.504317, "o", "        ],"]
[14.524317, "o", "\r\n"]
[14.534317, "o", "        \"root_causes\": ["]
[14.554317, "o", "\r\n"]
[14.564317, "o", "          \"acl\""]
[14.584317, "o", "\r\n"]
[14.594317, "o", "        ],"]
[14.614317, "o", "\r\n"]
[14.624317, "o", "        \"why_now\": \"Resource has been unsafe for 24 hours (threshold: 12 hours). Unsafe since 2026-01-14T00:00:00Z.\""]
[14.644317, "o", "\r\n"]
[14.654317, "o", "      },"]
[14.674317, "o", "\r\n"]
[14.684317, "o", "      \"invariant_severity\": \"critical\","]
[14.704317, "o", "\r\n"]
[14.714317, "o", "      \"mitigation\": {"]
[14.734317, "o", "\r\n"]
[14.744317, "o", "        \"description\": \"Bucket ACL grants write access to AllUsers or AuthenticatedUsers. Any anonymous or authenticated AWS user can upload or overwrite objects.\\n\","]
[14.764317, "o", "\r\n"]
[14.774317, "o", "        \"action\": \"Replace the bucket ACL with \\\"BucketOwnerFullControl\\\" or remove the public write grant. Enable S3 Public Access Block with BlockPublicAcls and IgnorePublicAcls set to true.\\n\","]
[14.794317, "o", "\r\n"]
[14.804317, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"visibility\\\": {\\n      \\\"public_write_via_acl\\\": false\\n    }\\n  }\\n}\\n\""]
[14.824317, "o", "\r\n"]
[14.834317, "o", "      },"]
[14.854317, "o", "\r\n"]
[14.864317, "o", "      \"remediation\": \"Replace the bucket ACL with \\\"BucketOwnerFullControl\\\" or remove the public write grant. Enable S3 Public Access Block with BlockPublicAcls and IgnorePublicAcls set to true.\\n\","]
[14.884317, "o", "\r\n"]
[14.894317, "o", "      \"fix_plan\": {"]
[14.914317, "o", "\r\n"]
[14.924317, "o", "        \"id\": \"fix-58254b10f4752ef3\","]
[14.944317, "o", "\r\n"]
[14.954317, "o", "        \"target\": {"]
[14.974317, "o", "\r\n"]
[14.984317, "o", "          \"resource_id\": \"platform-user-uploads\","]
[15.004317, "o", "\r\n"]
[15.014317, "o", "          \"resource_type\": \"aws_s3_bucket\""]
[15.034317, "o", "\r\n"]
