[15.424317, "o", "\r\n"]
[15.434317, "o", "            \"path\": \"properties.storage.controls.block_public_policy\","]
[15.454317, "o", "\r\n"]
[15.464317, "o", "            \"value\": true"]
[15.484317, "o", "\r\n"]
[15.494317, "o", "          },"]
[15.514317, "o", "\r\n"]
