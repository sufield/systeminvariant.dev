[15.124317, "o", "\r\n"]
[15.134317, "o", "          \"Ensure public access is not intentionally required for this resource.\""]
[15.154317, "o", "\r\n"]
[15.164317, "o", "        ],"]
[15.184317, "o", "\r\n"]
[15.194317, "o", "        \"actions\": ["]
