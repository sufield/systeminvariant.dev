[15.554317, "o", "            \"action_type\": \"set\","]
[15.574317, "o", "\r\n"]
[15.584317, "o", "            \"path\": \"properties.storage.controls.ignore_public_acls\","]
[15.604317, "o", "\r\n"]
[15.614317, "o", "            \"value\": true"]
[15.634317, "o", "\r\n"]
[15.644317, "o", "          },"]
[15.664317, "o", "\r\n"]
[15.674317, "o", "          {"]
[15.694317, "o", "\r\n"]
[15.704317, "o", "            \"action_type\": \"set\","]
[15.724317, "o", "\r\n"]
[15.734317, "o", "            \"path\": \"properties.storage.controls.restrict_public_buckets\","]
[15.754317, "o", "\r\n"]
[15.764317, "o", "            \"value\": true"]
[15.784317, "o", "\r\n"]
[15.794317, "o", "          }"]
[15.814317, "o", "\r\n"]
[15.824317, "o", "        ],"]
[15.844317, "o", "\r\n"]
[15.854317, "o", "        \"expected_effect\": \"Prevents public access by blocking policy and ACL based exposure paths.\""]
[15.874317, "o", "\r\n"]
[15.884317, "o", "      }"]
[15.904317, "o", "\r\n"]
[15.914317, "o", "    },"]
[15.934317, "o", "\r\n"]
[15.944317, "o", "    {"]
[15.964317, "o", "\r\n"]
[15.974317, "o", "      \"invariant_id\": \"INV.S3.AUTH.READ.001\","]
[15.994317, "o", "\r\n"]
[16.004317, "o", "      \"invariant_name\": \"No Authenticated-Users Read Access\","]
[16.024317, "o", "\r\n"]
[16.034317, "o", "      \"invariant_description\": \"S3 buckets must not grant read access to all authenticated AWS users. AuthenticatedUsers scope means any AWS account can read objects, which is nearly as dangerous as fully public access.\\n\","]
[16.054317, "o", "\r\n"]
[16.064317, "o", "      \"resource_id\": \"platform-user-uploads\","]
[16.084317, "o", "\r\n"]
[16.094317, "o", "      \"resource_type\": \"aws_s3_bucket\","]
[16.114317, "o", "\r\n"]
[16.124317, "o", "      \"resource_vendor\": \"aws\","]
[16.144317, "o", "\r\n"]
[16.154317, "o", "      \"evidence\": {"]
[16.174317, "o", "\r\n"]
[16.184317, "o", "        \"first_unsafe_at\": \"2026-01-14T00:00:00Z\","]
[16.204317, "o", "\r\n"]
[16.214317, "o", "        \"last_seen_unsafe_at\": \"2026-01-15T00:00:00Z\","]
[16.234317, "o", "\r\n"]
[16.244317, "o", "        \"unsafe_duration_hours\": 24,"]
[16.264317, "o", "\r\n"]
[16.274317, "o", "        \"threshold_hours\": 12,"]
[16.294317, "o", "\r\n"]
[16.304317, "o", "        \"matched_properties\": ["]
[16.324317, "o", "\r\n"]
[16.334317, "o", "          {"]
[16.354317, "o", "\r\n"]
[16.364317, "o", "            \"path\": \"storage.visibility.authenticated_users_read\","]
[16.384317, "o", "\r\n"]
[16.394317, "o", "            \"value\": true"]
[16.414317, "o", "\r\n"]
[16.424317, "o", "          }"]
[16.444317, "o", "\r\n"]
[16.454317, "o", "        ],"]
[16.474317, "o", "\r\n"]
[16.484317, "o", "        \"why_now\": \"Resource has been unsafe for 24 hours (threshold: 12 hours). Unsafe since 2026-01-14T00:00:00Z.\""]
[16.504317, "o", "\r\n"]
[16.514317, "o", "      },"]
[16.534317, "o", "\r\n"]
[16.544317, "o", "      \"invariant_severity\": \"high\","]
[16.564317, "o", "\r\n"]
[16.574317, "o", "      \"mitigation\": {"]
[16.594317, "o", "\r\n"]
[16.604317, "o", "        \"description\": \"Bucket grants read access to the AuthenticatedUsers group. Any AWS account holder worldwide can read objects, which is nearly as dangerous as fully public access.\\n\","]
[16.624317, "o", "\r\n"]
[16.634317, "o", "        \"action\": \"Remove the ACL grant to AuthenticatedUsers. Replace with specific IAM principals or use bucket policy with explicit account IDs. Enable S3 Public Access Block with IgnorePublicAcls set to true.\\n\","]
[16.654317, "o", "\r\n"]
[16.664317, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"visibility\\\": {\\n      \\\"authenticated_users_read\\\": false\\n    }\\n  }\\n}\\n\""]
[16.684317, "o", "\r\n"]
[16.694317, "o", "      },"]
[16.714317, "o", "\r\n"]
[16.724317, "o", "      \"remediation\": \"Remove the ACL grant to AuthenticatedUsers. Replace with specific IAM principals or use bucket policy with explicit account IDs. Enable S3 Public Access Block with IgnorePublicAcls set to true.\\n\""]
[16.744317, "o", "\r\n"]
[16.754317, "o", "    },"]
[16.774317, "o", "\r\n"]
[16.784317, "o", "    {"]
[16.804317, "o", "\r\n"]
[16.814317, "o", "      \"invariant_id\": \"INV.S3.CONTROLS.001\","]
[16.834317, "o", "\r\n"]
[16.844317, "o", "      \"invariant_name\": \"Public Access Block Must Be Enabled\","]
[16.864317, "o", "\r\n"]
[16.874317, "o", "      \"invariant_description\": \"S3 buckets must have the public access block fully enabled. When disabled, the bucket has no safety net against accidental public exposure from policy or ACL changes. This detects the enabling condition for public access, not the exposure itself.\\n\","]
[16.894317, "o", "\r\n"]
