[15.102972, "o", "\r\n"]
[15.112972, "o", "        \"cis_aws_v1.4.0\": \"2.1.5\","]
[15.132972, "o", "\r\n"]
[15.142972, "o", "        \"pci_dss_v3.2.1\": \"1.3.6\","]
[15.162972, "o", "\r\n"]
