[17.472972, "o", "\r\n"]
[17.482972, "o", "        \"description\": \"Bucket does not enforce HTTPS for data transfers. Requests over plain HTTP transmit data in cleartext.\\n\","]
[17.502972, "o", "\r\n"]
[17.512972, "o", "        \"action\": \"Add a bucket policy statement that denies all actions when aws:SecureTransport is false. This forces all API calls to use HTTPS.\\n\","]
[17.532972, "o", "\r\n"]
[17.542972, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"kind\\\": \\\"bucket\\\",\\n    \\\"encryption\\\": {\\n      \\\"in_transit_enforced\\\": true\\n    }\\n  }\\n}\\n\""]
[17.562972, "o", "\r\n"]
