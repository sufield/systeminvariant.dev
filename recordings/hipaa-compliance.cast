[14.622972, "o", "\r\n"]
[14.632972, "o", "        \"unsafe_duration_hours\": 24,"]
[14.652972, "o", "\r\n"]
[14.662972, "o", "        \"threshold_hours\": 12,"]
[14.682972, "o", "\r\n"]
[14.692972, "o", "        \"matched_properties\": ["]
