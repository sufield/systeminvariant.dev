[15.192972, "o", "\r\n"]
[15.202972, "o", "      },"]
[15.222972, "o", "\r\n"]
[15.232972, "o", "      \"mitigation\": {"]
[15.252972, "o", "\r\n"]
[15.262972, "o", "        \"description\": \"Public Access Block is not fully enabled. The bucket has no safety net against accidental public exposure from policy or ACL changes.\\n\","]
[15.282972, "o", "\r\n"]
[15.292972, "o", "        \"action\": \"Enable all four Public Access Block settings on the bucket: BlockPublicAcls, IgnorePublicAcls, BlockPublicPolicy, RestrictPublicBuckets.\\n\","]
[15.312972, "o", "\r\n"]
[15.322972, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"kind\\\": \\\"bucket\\\",\\n    \\\"controls\\\": {\\n      \\\"public_access_fully_blocked\\\": true\\n    }\\n  }\\n}\\n\""]
[15.342972, "o", "\r\n"]
[15.352972, "o", "      },"]
[15.372972, "o", "\r\n"]
[15.382972, "o", "      \"remediation\": \"Enable all four Public Access Block settings on the bucket: BlockPublicAcls, IgnorePublicAcls, BlockPublicPolicy, RestrictPublicBuckets.\\n\""]
[15.402972, "o", "\r\n"]
[15.412972, "o", "    },"]
[15.432972, "o", "\r\n"]
[15.442972, "o", "    {"]
[15.462972, "o", "\r\n"]
[15.472972, "o", "      \"invariant_id\": \"INV.S3.ENCRYPT.001\","]
[15.492972, "o", "\r\n"]
[15.502972, "o", "      \"invariant_name\": \"Encryption at Rest Required\","]
[15.522972, "o", "\r\n"]
[15.532972, "o", "      \"invariant_description\": \"S3 buckets must have server-side encryption enabled. Unencrypted storage is the top audit finding in regulated industries.\\n\","]
[15.552972, "o", "\r\n"]
[15.562972, "o", "      \"resource_id\": \"patient-records-east\","]
[15.582972, "o", "\r\n"]
