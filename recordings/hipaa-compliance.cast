[16.302972, "o", "\r\n"]
[16.312972, "o", "      },"]
[16.332972, "o", "\r\n"]
[16.342972, "o", "      \"mitigation\": {"]
[16.362972, "o", "\r\n"]
[16.372972, "o", "        \"description\": \"Bucket does not have server-side encryption enabled. Objects are stored unencrypted at rest.\\n\","]
[16.392972, "o", "\r\n"]
[16.402972, "o", "        \"action\": \"Enable default bucket encryption using SSE-S3 (AES256) or SSE-KMS. Use aws s3api put-bucket-encryption to set the default encryption configuration. For sensitive data, use SSE-KMS with a customer-managed key.\\n\","]
[16.422972, "o", "\r\n"]
[16.432972, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"kind\\\": \\\"bucket\\\",\\n    \\\"encryption\\\": {\\n      \\\"at_rest_enabled\\\": true\\n    }\\n  }\\n}\\n\""]
[16.452972, "o", "\r\n"]
[16.462972, "o", "      },"]
[16.482972, "o", "\r\n"]
[16.492972, "o", "      \"remediation\": \"Enable default bucket encryption using SSE-S3 (AES256) or SSE-KMS. Use aws s3api put-bucket-encryption to set the default encryption configuration. For sensitive data, use SSE-KMS with a customer-managed key.\\n\""]
[16.512972, "o", "\r\n"]
[16.522972, "o", "    },"]
[16.542972, "o", "\r\n"]
[16.552972, "o", "    {"]
[16.572972, "o", "\r\n"]
[16.582972, "o", "      \"invariant_id\": \"INV.S3.ENCRYPT.002\","]
[16.602972, "o", "\r\n"]
[16.612972, "o", "      \"invariant_name\": \"Transport Encryption Required\","]
[16.632972, "o", "\r\n"]
[16.642972, "o", "      \"invariant_description\": \"S3 buckets must enforce HTTPS via a deny policy on aws:SecureTransport=false. Without this, data transfers occur in plaintext.\\n\","]
