[17.682972, "o", "\r\n"]
[17.692972, "o", "      \"invariant_id\": \"INV.S3.ENCRYPT.003\","]
[17.712972, "o", "\r\n"]
[17.722972, "o", "      \"invariant_name\": \"PHI Buckets Must Use SSE-KMS with Customer-Managed Key\","]
[17.742972, "o", "\r\n"]
[17.752972, "o", "      \"invariant_description\": \"S3 buckets tagged with data-classification=phi must use SSE-KMS encryption with a customer-managed key (CMK), not the default AWS-managed key or SSE-S3. This ensures the organization controls key rotation, access policies, and audit logging for PHI data at rest.\\n\","]
[17.772972, "o", "\r\n"]
[17.782972, "o", "      \"resource_id\": \"patient-records-east\","]
[17.802972, "o", "\r\n"]
[17.812972, "o", "      \"resource_type\": \"aws_s3_bucket\","]
[17.832972, "o", "\r\n"]
[17.842972, "o", "      \"resource_vendor\": \"aws\","]
[17.862972, "o", "\r\n"]
[17.872972, "o", "      \"evidence\": {"]
[17.892972, "o", "\r\n"]
[17.902972, "o", "        \"first_unsafe_at\": \"2026-01-14T00:00:00Z\","]
[17.922972, "o", "\r\n"]
[17.932972, "o", "        \"last_seen_unsafe_at\": \"2026-01-15T00:00:00Z\","]
[17.952972, "o", "\r\n"]
