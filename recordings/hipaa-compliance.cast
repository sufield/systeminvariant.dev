[16.192972, "o", "      \"invariant_compliance\": {"]
[16.212972, "o", "\r\n"]
[16.222972, "o", "        \"cis_aws_v1.4.0\": \"2.1.1\","]
[16.242972, "o", "\r\n"]
[16.252972, "o", "        \"pci_dss_v3.2.1\": \"3.4\","]
[16.272972, "o", "\r\n"]
