[14.352972, "o", "\r\n"]
[14.362972, "o", "      \"invariant_id\": \"INV.S3.CONTROLS.001\","]
[14.382972, "o", "\r\n"]
[14.392972, "o", "      \"invariant_name\": \"Public Access Block Must Be Enabled\","]
[14.412972, "o", "\r\n"]
[14.422972, "o", "      \"invariant_description\": \"S3 buckets must have the public access block fully enabled. When disabled, the bucket has no safety net against accidental public exposure from policy or ACL changes. This detects the enabling condition for public access, not the exposure itself.\\n\","]
[14.442972, "o", "\r\n"]
[14.452972, "o", "      \"resource_id\": \"patient-records-east\","]
[14.472972, "o", "\r\n"]
[14.482972, "o", "      \"resource_type\": \"aws_s3_bucket\","]
[14.502972, "o", "\r\n"]
[14.512972, "o", "      \"resource_vendor\": \"aws\","]
[14.532972, "o", "\r\n"]
