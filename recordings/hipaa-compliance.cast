[18.282972, "o", "\r\n"]
[18.292972, "o", "      \"mitigation\": {"]
[18.312972, "o", "\r\n"]
[18.322972, "o", "        \"description\": \"PHI bucket is not using SSE-KMS with a customer-managed key. The organization lacks control over key rotation, access policies, and audit logging for PHI data at rest.\\n\","]
[18.342972, "o", "\r\n"]
[18.352972, "o", "        \"action\": \"Change the bucket default encryption to SSE-KMS and specify a customer-managed KMS key ARN. Ensure the KMS key policy grants access only to authorized principals. Enable KMS key rotation.\\n\","]
[18.372972, "o", "\r\n"]
[18.382972, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"tags\\\": {\\n      \\\"data-classification\\\": \\\"phi\\\"\\n    },\\n    \\\"encryption\\\": {\\n      \\\"algorithm\\\": \\\"aws:kms\\\",\\n      \\\"kms_key_id\\\": \\\"arn:aws:kms:us-east-1:123456789012:key/example-key-id\\\"\\n    }\\n  }\\n}\\n\""]
[18.402972, "o", "\r\n"]
[18.412972, "o", "      },"]
[18.432972, "o", "\r\n"]
[18.442972, "o", "      \"remediation\": \"Change the bucket default encryption to SSE-KMS and specify a customer-managed KMS key ARN. Ensure the KMS key policy grants access only to authorized principals. Enable KMS key rotation.\\n\""]
[18.462972, "o", "\r\n"]
[18.472972, "o", "    },"]
[18.492972, "o", "\r\n"]
[18.502972, "o", "    {"]
[18.522972, "o", "\r\n"]
[18.532972, "o", "      \"invariant_id\": \"INV.S3.ENCRYPT.004\","]
[18.552972, "o", "\r\n"]
[18.562972, "o", "      \"invariant_name\": \"Sensitive Data Requires KMS Encryption\","]
[18.582972, "o", "\r\n"]
[18.592972, "o", "      \"invariant_description\": \"S3 buckets with any non-public data classification must use SSE-KMS encryption with a customer-managed key, not SSE-S3 (AES256). AES256 uses AWS-managed keys with no customer control over key rotation, access policies, or audit trails. This fires on all classified data except explicitly public or non-sensitive buckets.\\n\","]
[18.612972, "o", "\r\n"]
