[15.367012, "o", "      \"invariant_name\": \"No Latent Public Read Exposure\","]
[15.387012, "o", "\r\n"]
[15.397012, "o", "      \"invariant_description\": \"S3 buckets must not have latent public read exposure where a public mechanism (policy or ACL) is masked only by Public Access Block. Removing PAB would immediately expose the bucket.\","]
