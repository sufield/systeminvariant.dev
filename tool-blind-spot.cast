[16.237012, "o", "      \"mitigation\": {"]
[16.257012, "o", "\r\n"]
[16.267012, "o", "        \"description\": \"Bucket has a policy or ACL granting public read, currently masked only by Public Access Block. Removing PAB would immediately expose the bucket.\\n\","]
[16.287012, "o", "\r\n"]
[16.297012, "o", "        \"action\": \"Remove the underlying public-granting policy statement or ACL entry so the bucket does not depend solely on PAB for protection. Then verify PAB remains enabled as defense-in-depth.\\n\","]
[16.317012, "o", "\r\n"]
[16.327012, "o", "        \"example\": \"{\\n  \\\"storage\\\": {\\n    \\\"visibility\\\": {\\n      \\\"latent_public_read\\\": false\\n    }\\n  }\\n}\\n\""]
[16.347012, "o", "\r\n"]
[16.357012, "o", "      },"]
[16.377012, "o", "\r\n"]
[16.387012, "o", "      \"remediation\": \"Remove the underlying public-granting policy statement or ACL entry so the bucket does not depend solely on PAB for protection. Then verify PAB remains enabled as defense-in-depth.\\n\","]
[16.407012, "o", "\r\n"]
